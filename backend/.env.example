# Backend environment variables for local development and free deployment
# H2 default URL is used if SPRING_DATASOURCE_URL is not set
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/portfolio_db;MODE=MySQL;DATABASE_TO_UPPER=false;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
JWT_SECRET=replace-with-secure-secret
CORS_ALLOWED_ORIGINS=http://localhost:3000
