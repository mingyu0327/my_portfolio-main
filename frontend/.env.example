# Google Gemini API (Google AI Studio)
# cp .env.example .env.local 후 키 입력 → npm start 재시작

REACT_APP_AI_API_KEY= 

# 선택 (기본: gemini-2.5-flash)
# REACT_APP_AI_MODEL=gemini-2.5-flash
# REACT_APP_AI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# API endpoint for the backend server
REACT_APP_API_BASE_URL=http://localhost:8080/api
